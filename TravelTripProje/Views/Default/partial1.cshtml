@using TravelTripProje.Models.Siniflar
@model List<Blog>

<div class="con-bot">
    @foreach (var x in Model)
    {
        <div class="left" style="width:400px;right:250px;">
            <div class="con-bot-left">
                <img src="@x.BlogImage" alt="" />
            </div>
            <div class="left-text">
                <h4>@x.Baslik </h4>
                <span>@x.Tarih.ToString("dd.MM.yyyy")</span>
                <p>@x.Aciklama.Substring(0, 80) ... <a href="/Blog/BlogDetay/@x.ID"><span>Devamını Oku>></span></a></p>
                
            </div>
        </div>
    }

    @Html.Action("Partial2", "Default")
</div>

