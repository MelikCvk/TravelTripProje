@model TravelTripProje.Models.Siniflar.Hakkimizda
@{
    ViewBag.Title = "Yeni Kayıt";
    Layout = "~/Views/_AdminLayout.cshtml";
}

<h2>Yeni Hakkımızda Kaydı</h2>
<br />
@using (Html.BeginForm("YeniHakkimizda", "Admin", FormMethod.Post))
{
    <div class="form-group">
        <label>Fotoğraf URL</label>
        <input type="text" name="FotoUrl" class="form-control" placeholder="Fotoğraf URL giriniz" />
    </div>
    <div class="form-group">
        <label>Açıklama</label>
        <textarea name="Aciklama" class="form-control" rows="5" placeholder="Açıklama giriniz"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a href="/Admin/Hakkimizda" class="btn btn-default">Geri Dön</a>
}