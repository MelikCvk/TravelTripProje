@model TravelTripProje.Models.Siniflar.Hakkimizda
@{
    ViewBag.Title = "Düzenle";
    Layout = "~/Views/_AdminLayout.cshtml";
}

<h2>Hakkımızda Düzenle</h2>
<br />
@using (Html.BeginForm("HakkimizdaGetir", "Admin", FormMethod.Post))
{
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-group">
        <label>Fotograf URL</label>
        <input type="text" name="FotoUrl" class="form-control" value="@Model.FotoUrl" />
    </div>
    <div class="form-group">
        <label>Acıklama</label>
        <textarea name="Aciklama" class="form-control" rows="5">@Model.Aciklama</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Güncelle</button>
    <a href="/Admin/Hakkimizda" class="btn btn-default">Geri Dön</a>
}